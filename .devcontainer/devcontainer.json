{
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "vadimcn.vscode-lldb",
                "GitHub.copilot",
                "eamodio.gitlens",
                "bradymholt.pgformatter",
                "rust-lang.rust-analyzer",
                "ms-vscode.cpptools",
                "henriiik.docker-linter"
            ]
        }
    },
    "postStartCommand": "bash .devcontainer/scripts/setup_minio.sh && bash .devcontainer/scripts/setup_azurite.sh",
    "forwardPorts": [
        5432
    ],
    "capAdd": [
        "SYS_PTRACE"
    ]
}
